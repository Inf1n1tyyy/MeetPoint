{
  "name": "meetpoint-tests",
  "version": "1.0.0",
  "description": "Тесты для проекта MeetPoint",
  "private": true,
  "scripts": {
    "test:unit":        "jest tests/unit/ --testPathPattern=unit",
    "test:integration": "jest tests/integration/ --testPathPattern=integration --runInBand",
    "test:frontend":    "vitest run tests/frontend/",
    "test:e2e":         "playwright test tests/e2e/",
    "test:load":        "node tests/load/load.mjs",
    "test:ws":          "node tests/load/ws-load.mjs",
    "test:all":         "npm run test:unit && npm run test:integration && npm run test:frontend"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testTimeout": 30000,
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "esModuleInterop": true,
          "strict": false
        }
      }
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "autocannon": "^7.15.0",
    "axios": "^1.7.0",
    "jest": "^29.7.0",
    "jsdom": "^25.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  }
}
